        cls.point_light_blue = int(blue)
        cls.point_light_green = int(green)
        cls.point_light_red = int(red)
        cls.point_light_range = int(range)
        cls.point_light_type = light
        cls.world_type = world
    
    @classmethod
    def AddInstance(cls) : cls.Instance += 1

class BallOption:
    Option = 0
    
    def __init__(self) : pass
    
    @classmethod
    def ResetOption(cls) : cls.Option = 0
    
    @classmethod
    def MorphCall(cls, ball):
        def SwitchMorphIndex(Ball, Number):
                    match Ball:
                        case "powerball" : return cls.Option
                        case "marbleball" : return Number + 1
                        case "airball" : return Number + 2
                        case "steelball" : return Number + 3
                        case _ : return cls.Option
        cls.Option = SwitchMorphIndex(ball, cls.Option)

